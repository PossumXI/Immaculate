# Cloudflare account and API token.
# Token scopes from Cloudflare docs:
# - Workers AI Read
# - Workers AI Write
# - AI Gateway Read
# - AI Gateway Edit
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# The deployed worker still serves only the public Q identity.
CLOUDFLARE_Q_NAME=Q

# Cloudflare-compatible base model and LoRA identifier.
# Keep these explicit in env rather than hard-coding another model into repo code.
CLOUDFLARE_Q_BASE_MODEL=
CLOUDFLARE_Q_LORA_NAME=

# AI Gateway routing and worker protection.
CLOUDFLARE_AI_GATEWAY_ID=default
CLOUDFLARE_Q_WORKER_API_KEY=

# Optional deploy/eval overrides.
CLOUDFLARE_Q_WORKER_NAME=immaculate-q-cloudflare
CLOUDFLARE_Q_WORKER_ROUTE=
CLOUDFLARE_Q_WORKER_URL=
CLOUDFLARE_GATEWAY_SKIP_CACHE=false
CLOUDFLARE_GATEWAY_CACHE_TTL=0
CLOUDFLARE_EVAL_LIMIT=8

# Optional explicit paths.
CLOUDFLARE_ADAPTER_SOURCE_DIR=
# Leave blank to keep the controller on session-scoped defaults.
CLOUDFLARE_ADAPTER_EXPORT_DIR=
CLOUDFLARE_EVAL_BUNDLE_PATH=

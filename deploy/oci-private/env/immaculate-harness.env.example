IMMACULATE_REPO_ROOT=/opt/immaculate/src
IMMACULATE_IMAGE_NAME=immaculate/harness:oci-private
IMMACULATE_CONTAINER_NAME=immaculate-harness

# Bind the host-side listener only to the private VNIC address.
IMMACULATE_PRIVATE_BIND_IP=10.0.1.10
IMMACULATE_PUBLISHED_PORT=8787
IMMACULATE_ALLOWED_OPERATOR_CIDR=10.0.0.0/16

# Inside the container the harness listens on 0.0.0.0:8787.
IMMACULATE_HARNESS_HOST=0.0.0.0
IMMACULATE_HARNESS_PORT=8787
IMMACULATE_TICK_MS=180

IMMACULATE_RUNTIME_DIR=/var/lib/immaculate/runtime
IMMACULATE_LOG_DIR=/var/log/immaculate

IMMACULATE_NODE_LABEL="Immaculate OCI Private Node"
IMMACULATE_NODE_LOCALITY=oci-phx-ad-1/rack-a
IMMACULATE_NODE_CONTROL_URL=http://10.0.1.10:8787
IMMACULATE_LOCAL_WORKER_SLOTS=4
IMMACULATE_OLLAMA_URL=http://10.0.2.20:11434

IMMACULATE_CPU_LIMIT=4
IMMACULATE_MEMORY_LIMIT=8g
IMMACULATE_PIDS_LIMIT=512

# Secret files should be root-readable only. The run script loads these into
# environment variables right before podman starts the container.
IMMACULATE_API_KEY_FILE=/etc/immaculate/secrets/immaculate-api-key
IMMACULATE_FEDERATION_SHARED_SECRET_FILE=/etc/immaculate/secrets/federation-shared-secret
WANDB_API_KEY_FILE=/etc/immaculate/secrets/wandb-api-key

# Optional OCI Vault pull-through using instance principals.
OCI_CLI_AUTH=instance_principal
OCI_IMMACULATE_API_KEY_SECRET_OCID=
OCI_IMMACULATE_FEDERATION_SECRET_OCID=
OCI_WANDB_API_KEY_SECRET_OCID=

IMMACULATE_REPO_ROOT=/opt/immaculate/src
IMMACULATE_Q_TRAINING_PYTHON=python3
IMMACULATE_Q_TRAINING_RUNTIME_DIR=/var/lib/immaculate/q-training
IMMACULATE_Q_TRAINING_LOG_DIR=/var/log/immaculate/q-training
IMMACULATE_Q_TRAINING_BUNDLE_PATH=/var/lib/immaculate/q-training/session-bundle.tar.gz
IMMACULATE_Q_TRAINING_DRY_RUN=false

# OCI controller auth for launching the instance.
# Local controller launches usually use API-key auth from a workstation OCI config.
# The launched OCI node should still use instance principals for bundle/secret fetches.
OCI_CLI_AUTH=
OCI_CLI_CONFIG_FILE=
OCI_CLI_PROFILE=DEFAULT
OCI_CLI_BIN=oci

# OCI instance launch target.
# OCI_TARGET_REGION is the compute region for the GPU node.
# OCI_OBJECT_STORAGE_REGION is the bucket region the remote node must read from.
OCI_COMPARTMENT_OCID=
OCI_SUBNET_OCID=
OCI_AVAILABILITY_DOMAIN=
OCI_IMAGE_OCID=
OCI_SHAPE=
OCI_TARGET_REGION=
OCI_OBJECT_STORAGE_REGION=
OCI_SSH_AUTHORIZED_KEYS_FILE=
OCI_Q_TRAINING_DISPLAY_NAME_PREFIX=immaculate-q-train

# Session bundle staging through Object Storage.
OCI_OBJECT_STORAGE_NAMESPACE=
OCI_OBJECT_STORAGE_BUCKET=
OCI_Q_TRAINING_BUNDLE_OBJECT=
OCI_Q_TRAINING_BUNDLE_SHA256=

# Remote training secrets on the launched instance. Prefer Vault or root-readable
# files over plain-text tokens in the env file.
HF_TOKEN_FILE=/etc/immaculate/secrets/hf-token
WANDB_API_KEY_FILE=/etc/immaculate/secrets/wandb-api-key
OCI_Q_TRAINING_HF_TOKEN_SECRET_OCID=
OCI_Q_TRAINING_WANDB_API_KEY_SECRET_OCID=

# Tracking and cache paths on the training node.
WANDB_ENTITY=
WANDB_PROJECT=immaculate
WANDB_MODE=offline
HF_HOME=/var/lib/immaculate/q-training/cache/hf
TRANSFORMERS_CACHE=/var/lib/immaculate/q-training/cache/transformers
WANDB_DIR=/var/lib/immaculate/q-training/cache/wandb

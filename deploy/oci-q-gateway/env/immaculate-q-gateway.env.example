IMMACULATE_REPO_ROOT=/opt/immaculate/src
IMMACULATE_Q_GATEWAY_IMAGE_NAME=immaculate/q-gateway:oci-private
IMMACULATE_Q_GATEWAY_CONTAINER_NAME=immaculate-q-gateway

# Bind only to the private VNIC address for the gateway host.
IMMACULATE_Q_GATEWAY_PRIVATE_BIND_IP=10.0.3.10
IMMACULATE_Q_GATEWAY_PUBLISHED_PORT=8788
IMMACULATE_Q_GATEWAY_ALLOWED_CLIENT_CIDR=10.0.0.0/16

# Inside the container the dedicated Q gateway listens on 0.0.0.0:8788.
IMMACULATE_Q_GATEWAY_HOST=0.0.0.0
IMMACULATE_Q_GATEWAY_PORT=8788
IMMACULATE_Q_GATEWAY_ALLOWED_ORIGINS=
IMMACULATE_Q_GATEWAY_MAX_MESSAGES=24
IMMACULATE_Q_GATEWAY_MAX_INPUT_CHARS=16000
IMMACULATE_Q_GATEWAY_TIMEOUT_MS=180000
IMMACULATE_Q_GATEWAY_PRIMARY_FAILURE_THRESHOLD=2
IMMACULATE_Q_GATEWAY_PRIMARY_COOLDOWN_MS=120000

IMMACULATE_RUNTIME_DIR=/var/lib/immaculate/runtime
IMMACULATE_Q_API_KEYS_PATH=/var/lib/immaculate/runtime/q-api-keys.json
IMMACULATE_OLLAMA_URL=http://10.0.2.20:11434
IMMACULATE_Q_API_DEFAULT_RPM=60
IMMACULATE_Q_API_DEFAULT_BURST=60
IMMACULATE_Q_API_DEFAULT_MAX_CONCURRENT=2

IMMACULATE_Q_GATEWAY_LOG_DIR=/var/log/immaculate/q-gateway

IMMACULATE_Q_GATEWAY_CPU_LIMIT=1
IMMACULATE_Q_GATEWAY_MEMORY_LIMIT=1g
IMMACULATE_Q_GATEWAY_PIDS_LIMIT=128

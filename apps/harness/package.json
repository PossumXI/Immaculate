{
  "name": "@immaculate/harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark": "tsx src/benchmark-cli.ts",
    "benchmark:durability:torture": "tsx src/benchmark-cli.ts --pack=durability-torture",
    "benchmark:latency:60s": "tsx src/benchmark-cli.ts --pack=latency-benchmark-60s",
    "benchmark:gate": "tsx src/benchmark-gate-cli.ts",
    "benchmark:gate:all": "tsx src/benchmark-gate-cli.ts --all",
    "benchmark:neurodata": "tsx src/benchmark-cli.ts --pack=neurodata-external",
    "benchmark:publish:wandb": "tsx src/wandb-publish-cli.ts",
    "benchmark:soak:60m": "tsx src/benchmark-cli.ts --pack=latency-soak-60m",
    "benchmark:temporal": "tsx src/benchmark-cli.ts --pack=temporal-baseline",
    "benchmark:export:wandb": "tsx src/wandb-export-cli.ts",
    "ollama:alias:q": "tsx src/q-alias-cli.ts --",
    "training-data:curate": "tsx src/training-data-cli.ts",
    "training-data:list": "tsx src/training-data-cli.ts list",
    "training-data:show": "tsx src/training-data-cli.ts show",
    "training-data:smoke": "tsx src/training-data-smoke.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@immaculate/core": "file:../../packages/core",
    "@temporalio/client": "^1.12.2",
    "@temporalio/testing": "^1.12.2",
    "@temporalio/worker": "^1.12.2",
    "@temporalio/workflow": "^1.12.2",
    "fastify": "^5.8.4",
    "h5wasm": "^0.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}

{
  "sessionId": "q-hybrid-session-example",
  "q": {
    "trainingLockPath": ".training-output/q/latest-training-lock.json",
    "configPath": "training/q/q_lora_config.long_context.example.json",
    "mixManifestPath": ".training-output/q/q-mix-longctx-v2.manifest.json",
    "curationRunPath": ".training-output/training-data/runs/<run-id>/run.json",
    "benchmarkCorpusPath": "docs/wiki/Q-Benchmark-Corpus.json",
    "benchmarkCorpusJsonlPath": ".training-output/q/q-benchmark-corpus.jsonl",
    "failureCorpusPath": "docs/wiki/Q-Failure-Corpus.json"
  },
  "immaculate": {
    "bundleOutputPath": ".training-output/immaculate/immaculate-training-bundle-q-hybrid-session-example.json"
  },
  "local": {
    "enabled": true,
    "python": "python",
    "mode": "dry-run",
    "extraArgs": []
  },
  "cloud": {
    "enabled": true,
    "provider": "oci",
    "mode": "launch",
    "requiredEnv": [
      "OCI_COMPARTMENT_OCID",
      "OCI_SUBNET_OCID",
      "OCI_AVAILABILITY_DOMAIN",
      "OCI_IMAGE_OCID",
      "OCI_SHAPE",
      "OCI_OBJECT_STORAGE_NAMESPACE",
      "OCI_OBJECT_STORAGE_BUCKET"
    ],
    "optionalEnv": [
      "HF_TOKEN",
      "HUGGINGFACE_TOKEN",
      "WANDB_API_KEY",
      "WANDB_ENTITY",
      "WANDB_PROJECT",
      "OCI_CLI_AUTH",
      "OCI_CLI_CONFIG_FILE",
      "OCI_CLI_PROFILE",
      "OCI_CONFIG_FILE",
      "OCI_PROFILE",
      "OCI_Q_TRAINING_HF_TOKEN_SECRET_OCID",
      "OCI_Q_TRAINING_WANDB_API_KEY_SECRET_OCID",
      "WANDB_MODE"
    ],
    "envFilePath": [
      "deploy/oci-training/env/immaculate-q-training.env.example"
    ],
    "inlineEnv": {
      "WANDB_MODE": "offline"
    },
    "launchCommand": [
      "bash",
      "deploy/oci-training/scripts/launch-oci-q-training.sh",
      "--session-manifest",
      "training/q/hybrid_training_session.example.json",
      "--env-file",
      "deploy/oci-training/env/immaculate-q-training.env.example"
    ],
    "notes": "Fill the OCI launch target OCIDs plus local controller auth through OCI_CLI_CONFIG_FILE/OCI_CLI_PROFILE for API-key launches. The session doctor can materialize a corrected session-local controller config from ~/.oci/config when it exists. Prefer OCI Vault secret OCIDs over plain-text tokens, and keep the launched OCI node on instance principal auth."
  },
  "artifacts": {
    "sessionRoot": ".training-output/q/sessions/q-hybrid-session-example",
    "wikiJsonPath": "docs/wiki/Q-Hybrid-Training.json",
    "wikiMarkdownPath": "docs/wiki/Q-Hybrid-Training.md"
  },
  "policy": {
    "buildImmaculateBundle": true,
    "allowCloudLaunchWhenDoctorFails": false
  }
}

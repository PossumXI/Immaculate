{
  "run_name": "q-defsec-code-longctx-v2",
  "alias_name": "Q",
  "base_model": "Q-LINEAGE-CHECKPOINT",
  "train_dataset_path": ".training-output/q/q-mix-longctx-v2.jsonl",
  "training_lock_path": ".training-output/q/latest-training-lock.json",
  "output_dir": ".training-output/q/runs/q-defsec-code-longctx-v2",
  "max_seq_length": 8192,
  "learning_rate": 0.00015,
  "warmup_ratio": 0.08,
  "lr_scheduler_type": "cosine",
  "num_train_epochs": 2,
  "per_device_train_batch_size": 1,
  "gradient_accumulation_steps": 16,
  "lora_rank": 32,
  "lora_alpha": 64,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "modules_to_save": [
    "lm_head",
    "embed_tokens"
  ],
  "bf16": true,
  "logging_steps": 10,
  "save_steps": 250,
  "report_to": [
    "wandb"
  ]
}

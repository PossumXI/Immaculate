{
  "name": "immaculate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "benchmark": "npm run benchmark -w @immaculate/harness",
    "benchmark:durability:torture": "npm run benchmark -w @immaculate/harness -- --pack=durability-torture",
    "benchmark:latency:60s": "npm run benchmark -w @immaculate/harness -- --pack=latency-benchmark-60s",
    "benchmark:neurodata": "npm run benchmark -w @immaculate/harness -- --pack=neurodata-external",
    "benchmark:gate": "npm run benchmark:gate -w @immaculate/harness",
    "benchmark:gate:all": "npm run benchmark:gate:all -w @immaculate/harness",
    "benchmark:harbor:report": "npm run benchmark:harbor:report -w @immaculate/harness",
    "benchmark:harbor:soak": "npm run benchmark:harbor:soak -w @immaculate/harness",
    "benchmark:q:sweep:report": "npm run benchmark:q:sweep:report -w @immaculate/harness",
    "benchmark:publish:wandb": "npm run benchmark:publish:wandb -w @immaculate/harness",
    "benchmark:soak:60m": "npm run benchmark -w @immaculate/harness -- --pack=latency-soak-60m",
    "benchmark:temporal": "npm run benchmark -w @immaculate/harness -- --pack=temporal-baseline",
    "benchmark:export:wandb": "npm run benchmark:export:wandb -w @immaculate/harness",
    "bridgebench": "npm run bridgebench -w @immaculate/harness",
    "bridgebench:soak": "npm run bridgebench:soak -w @immaculate/harness",
    "compare:models": "npm run compare:models -w @immaculate/harness",
    "q:failure-corpus": "python ./training/q/build_q_failure_corpus.py",
    "q:benchmark:corpus": "python ./training/q/build_q_benchmark_corpus.py",
    "q:training:promote-benchmark": "python ./training/q/promote_q_benchmark_lineage.py",
    "q:oci:capacity": "python ./training/q/probe_oci_region_capacity.py",
    "q:oci:limit-request": "python ./training/q/create_oci_region_limit_request.py",
    "q:hf:jobs": "python ./training/q/launch_hf_jobs_training.py",
    "q:colab:export": "python ./training/q/export_colab_free_training.py",
    "ollama:alias:q": "tsx ./apps/harness/src/q-alias-cli.ts --",
    "banner": "npm run banner -w @immaculate/harness",
    "q:gateway": "tsx ./apps/harness/src/q-gateway.ts",
    "q:gateway:validate": "tsx ./apps/harness/src/q-gateway-validate.ts",
    "q:release-gate": "tsx ./apps/harness/src/q-release-gate.ts",
    "release:surface": "tsx ./apps/harness/src/release-surface.ts",
    "q:keys": "tsx ./apps/harness/src/q-api-key-cli.ts",
    "q:training:lock": "python ./training/q/build_q_training_lock.py",
    "q:training:doctor": "python ./training/q/run_q_training_session.py --doctor",
    "q:training:session": "python ./training/q/run_q_training_session.py",
    "immaculate:training:bundle": "python ./training/immaculate/build_immaculate_training_bundle.py",
    "training-data:curate": "tsx ./apps/harness/src/training-data-cli.ts curate",
    "training-data:list": "tsx ./apps/harness/src/training-data-cli.ts list",
    "training-data:show": "tsx ./apps/harness/src/training-data-cli.ts show",
    "training-data:smoke": "tsx ./apps/harness/src/training-data-smoke.ts",
    "build": "npm run build -w @immaculate/core && npm run build -w @immaculate/harness && npm run build -w @immaculate/tui && npm run build -w @immaculate/dashboard",
    "dev:dashboard": "npm run dev -w @immaculate/dashboard",
    "dev:harness": "npm run dev -w @immaculate/harness",
    "dev:tui": "npm run dev -w @immaculate/tui",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "wandb:bootstrap": "node ./scripts/bootstrap-wandb.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
